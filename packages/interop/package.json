{
  "name": "@helia/interop",
  "version": "10.2.5",
  "description": "Interop tests for Helia",
  "license": "Apache-2.0 OR MIT",
  "homepage": "https://github.com/ipfs/helia/tree/main/packages/interop#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ipfs/helia.git"
  },
  "bugs": {
    "url": "https://github.com/ipfs/helia/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "IPFS"
  ],
  "bin": {
    "helia-interop": "./dist/src/bin.js"
  },
  "type": "module",
  "types": "./dist/src/index.d.ts",
  "files": [
    "src",
    "dist",
    "!dist/test",
    "!**/*.tsbuildinfo"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "module-sync": "./dist/src/index.js"
    }
  },
  "scripts": {
    "clean": "aegir clean",
    "lint": "aegir lint",
    "dep-check": "aegir dep-check",
    "doc-check": "aegir doc-check",
    "build": "aegir build",
    "test": "aegir test",
    "test:chrome": "aegir test -t browser --cov",
    "test:chrome-webworker": "aegir test -t webworker",
    "test:firefox": "aegir test -t browser -- --browser firefox",
    "test:firefox-webworker": "aegir test -t webworker -- --browser firefox",
    "test:node": "aegir test -t node --cov -- --exit",
    "test:electron-main": "aegir test -t electron-main --cov -- --exit"
  },
  "dependencies": {
    "@helia/bitswap": "^3.2.3",
    "@helia/car": "^5.4.2",
    "@helia/dag-cbor": "^5.1.1",
    "@helia/dag-json": "^5.1.1",
    "@helia/delegated-routing-client": "^0.0.0",
    "@helia/dnslink": "^1.2.1",
    "@helia/interface": "^6.2.1",
    "@helia/ipns": "^9.2.1",
    "@helia/json": "^5.1.1",
    "@helia/libp2p": "^0.0.0",
    "@helia/mfs": "^7.1.1",
    "@helia/strings": "^5.1.1",
    "@helia/unixfs": "^7.2.1",
    "@ipld/car": "^5.4.6",
    "@ipld/dag-cbor": "^10.0.1",
    "@ipld/dag-pb": "^4.1.7",
    "@libp2p/floodsub": "^11.0.23",
    "@libp2p/interface": "^3.2.3",
    "@libp2p/kad-dht": "^16.3.2",
    "@libp2p/keychain": "^6.1.2",
    "@libp2p/peer-id": "^6.0.10",
    "@libp2p/utils": "^7.2.2",
    "@libp2p/websockets": "^10.1.14",
    "@multiformats/multiaddr": "^13.0.3",
    "@multiformats/sha3": "^4.0.0",
    "aegir": "^48.0.11",
    "helia": "^6.1.4",
    "ipfs-unixfs-importer": "^17.0.1",
    "ipfsd-ctl": "^17.0.0",
    "it-all": "^3.0.11",
    "it-drain": "^3.0.12",
    "it-last": "^3.0.11",
    "it-map": "^3.1.6",
    "it-to-buffer": "^5.0.0",
    "kubo": "^0.42.0",
    "kubo-rpc-client": "^7.1.0",
    "libp2p": "^3.3.3",
    "multiformats": "^14.0.0",
    "uint8arrays": "^6.1.1",
    "wherearewe": "^2.0.1"
  },
  "browser": {
    "./src/fixtures/create-helia.ts": "./src/fixtures/create-helia.browser.ts",
    "./src/fixtures/create-kubo.ts": "./src/fixtures/create-kubo.browser.ts",
    "./dist/src/bin.js": "./dist/src/index.js",
    "kubo": false
  },
  "sideEffects": false
}
