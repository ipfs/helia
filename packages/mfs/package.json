{
  "name": "@helia/mfs",
  "version": "7.1.1",
  "description": "A mutable filesystem powered by Helia",
  "license": "Apache-2.0 OR MIT",
  "homepage": "https://github.com/ipfs/helia/tree/main/packages/mfs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ipfs/helia.git"
  },
  "bugs": {
    "url": "https://github.com/ipfs/helia/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "IPFS"
  ],
  "type": "module",
  "types": "./dist/src/index.d.ts",
  "files": [
    "src",
    "dist",
    "!dist/test",
    "!**/*.tsbuildinfo"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "module-sync": "./dist/src/index.js"
    }
  },
  "scripts": {
    "clean": "aegir clean",
    "lint": "aegir lint",
    "dep-check": "aegir dep-check",
    "doc-check": "aegir doc-check",
    "build": "aegir build",
    "test": "aegir test",
    "test:chrome": "aegir test -t browser --cov",
    "test:chrome-webworker": "aegir test -t webworker",
    "test:firefox": "aegir test -t browser -- --browser firefox",
    "test:firefox-webworker": "aegir test -t webworker -- --browser firefox",
    "test:node": "aegir test -t node --cov",
    "test:electron-main": "aegir test -t electron-main"
  },
  "dependencies": {
    "@helia/unixfs": "^7.2.1",
    "@libp2p/interface": "^3.2.3",
    "interface-blockstore": "^7.0.1",
    "interface-datastore": "^10.0.1",
    "ipfs-unixfs": "^13.0.0",
    "ipfs-unixfs-exporter": "^16.0.2",
    "ipfs-unixfs-importer": "^17.0.1",
    "it-map": "^3.1.6",
    "multiformats": "^14.0.0"
  },
  "devDependencies": {
    "@ipld/dag-pb": "^4.1.7",
    "@libp2p/logger": "^6.2.8",
    "aegir": "^48.0.11",
    "blockstore-core": "^7.0.1",
    "datastore-core": "^12.0.1",
    "delay": "^7.0.0",
    "it-all": "^3.0.11",
    "it-drain": "^3.0.12",
    "it-first": "^3.0.11",
    "it-last": "^3.0.11",
    "it-to-buffer": "^5.0.0",
    "uint8arrays": "^6.1.1"
  },
  "sideEffects": false
}
